# Copy this file to .env and fill in the value.
#
# After deploying SST (`npx sst deploy --stage production`),
# copy the chatUrl output here. Also add it as the VITE_CHAT_URL
# secret in GitHub repo Settings → Secrets so CI builds pick it up.
VITE_CHAT_URL=https://<your-api-id>.execute-api.ap-east-1.amazonaws.com/chat
